{
    "name": "nozule/nozule-suite",
    "description": "Nozule - A comprehensive hotel booking management system for WordPress",
    "type": "wordpress-plugin",
    "version": "1.10.1",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.0"
    },
    "autoload": {
        "psr-4": {
            "Nozule\\": "includes/"
        }
    },
    "authors": [
        {
            "name": "hdqah.com",
            "homepage": "https://hdqah.com"
        }
    ],
    "autoload-dev": {
        "psr-4": {
            "Nozule\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "mockery/mockery": "^1.6"
    }
}
